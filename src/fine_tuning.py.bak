"""Fine-tuning integration for AutoMISC.

Supports both local fine-tuning (via Hugging Face Transformers + PEFT) and OpenAI fine-tuning.
"""
import json
import os
import random
from dataclasses import dataclass
from pathlib import Path
from typing import Dict, List, Optional

import pandas as pd
from hydra.utils import log

try:
    import openai
except ImportError:
    openai = None


@dataclass
class FineTuneOutputPaths:
    training_file: Optional[Path] = None
    validation_file: Optional[Path] = None
    job_metadata: Optional[Path] = None
    model_dir: Optional[Path] = None


def get_annotated_csv_path(cfg) -> Path:
    return Path('data/annotated') / (
        f"{cfg.input_dataset.name}_"
        f"{cfg.input_dataset.subset}_"
        f"{cfg.annotator.class_structure}_"
        f"{cfg.annotator.model.rsplit('/', 1)[-1]}_"
        f"{cfg.annotator.context_mode}_"
        f"{cfg.annotator.num_context_turns if cfg.annotator.context_mode == 'interval' else ''}"
        f"_annotated.csv"
    )


def resolve_label_field(cfg) -> str:
    if cfg.fine_tuning.label_field != 'auto':
        return cfg.fine_tuning.label_field

    return 't2_label_auto' if cfg.annotator.class_structure == 'tiered' else 'label_auto'


def build_examples(cfg, df: pd.DataFrame) -> List[Dict[str, str]]:
    label_field = resolve_label_field(cfg)
    if label_field not in df.columns:
        raise ValueError(
            f"Fine-tuning label field '{label_field}' not found in annotated data columns: {list(df.columns)}"
        )

    examples: List[Dict[str, str]] = []
    for _, row in df.iterrows():
        label = row.get(label_field)
        if pd.isna(label) or str(label).strip() == '':
            continue

        prompt_parts = [f"Speaker: {row['speaker']}", f"Utterance: {row['utt_text']}" ]
        prompt = "\n\n".join(prompt_parts) + "\n\nLabel:"
        completion = f" {label}\n"

        examples.append({
            'prompt': prompt,
            'completion': completion,
        })

    if not examples:
        raise ValueError("No valid training examples could be built from annotated data.")

    log.info(f"Built {len(examples)} fine-tuning examples using field '{label_field}'.")
    return examples


def write_jsonl(examples: List[Dict[str, str]], output_path: Path) -> None:
    output_path.parent.mkdir(parents=True, exist_ok=True)
    with output_path.open('w', encoding='utf-8') as handle:
        for example in examples:
            handle.write(json.dumps(example, ensure_ascii=False) + '\n')

    log.info(f"Saved JSONL file to {output_path}")


def split_examples(cfg, examples: List[Dict[str, str]]) -> tuple[List[Dict[str, str]], Optional[List[Dict[str, str]]]]:
    split = float(cfg.fine_tuning.validation_split)
    if split <= 0.0:
        return examples, None

    seed = int(cfg.fine_tuning.seed)
    random.Random(seed).shuffle(examples)
    n_valid = int(len(examples) * split)
    if n_valid < 1:
        log.warning("Validation split requested, but dataset is too small to create a validation set. Using all examples for training.")
        return examples, None

    return examples[n_valid:], examples[:n_valid]


def upload_file_to_openai(file_path: Path) -> str:
    if openai is None:
        raise ImportError("OpenAI SDK is required for OpenAI fine-tuning. Install it with pip install openai.")

    with file_path.open('rb') as file_obj:
        upload = openai.File.create(file=file_obj, purpose='fine-tune')
    file_id = upload.id
    log.info(f"Uploaded file {file_path.name} to OpenAI as file ID {file_id}")
    return file_id


def create_fine_tune_job(training_file_id: str, cfg, validation_file_id: Optional[str] = None) -> dict:
    if cfg.fine_tuning.provider != 'openai':
        raise NotImplementedError("OpenAI fine-tuning is only available when fine_tuning.provider=openai.")

    if openai is None:
        raise ImportError("OpenAI SDK is required for OpenAI fine-tuning. Install it with pip install openai.")

    params = {
        'training_file': training_file_id,
        'model': cfg.fine_tuning.base_model,
        'n_epochs': int(cfg.fine_tuning.max_epochs),
    }

    if cfg.fine_tuning.batch_size and int(cfg.fine_tuning.batch_size) > 0:
        params['batch_size'] = int(cfg.fine_tuning.batch_size)

    if validation_file_id is not None:
        params['validation_file'] = validation_file_id

    if cfg.fine_tuning.suffix:
        params['suffix'] = cfg.fine_tuning.suffix

    job = openai.FineTune.create(**params)
    log.info(f"Created OpenAI fine-tune job: {job.id}")
    return job


def tokenize_prompt_completion(example: Dict[str, str], tokenizer, cfg) -> Dict[str, List[int]]:
    prompt = example['prompt']
    completion = example['completion']

    tokenized_prompt = tokenizer(
        prompt,
        truncation=True,
        max_length=int(cfg.fine_tuning.max_length),
        add_special_tokens=False,
    )
    tokenized_completion = tokenizer(
        completion,
        truncation=True,
        max_length=int(cfg.fine_tuning.max_target_length),
        add_special_tokens=False,
    )

    input_ids = tokenized_prompt['input_ids'] + tokenized_completion['input_ids']
    labels = [-100] * len(tokenized_prompt['input_ids']) + tokenized_completion['input_ids']

    if tokenizer.eos_token_id is not None:
        input_ids.append(tokenizer.eos_token_id)
        labels.append(tokenizer.eos_token_id)

    return {
        'input_ids': input_ids,
        'labels': labels,
    }


def run_local_fine_tuning(cfg, train_examples: List[Dict[str, str]], valid_examples: Optional[List[Dict[str, str]]]) -> FineTuneOutputPaths:
    try:
        import torch
        from datasets import Dataset
        from transformers import (
            AutoModelForCausalLM,
            AutoTokenizer,
            Trainer,
            TrainingArguments,
            default_data_collator,
        )
    except ImportError as exc:
        raise ImportError(
            "Local fine-tuning requires torch, transformers, and datasets. "
            "Install them with pip install torch transformers datasets accelerate peft"
        ) from exc

    use_peft = bool(getattr(cfg.fine_tuning, 'use_peft', False))
    if use_peft:
        try:
            from peft import LoraConfig, get_peft_model
        except ImportError as exc:
            raise ImportError("Local LoRA fine-tuning requires peft. Install it with pip install peft") from exc

    tokenizer = AutoTokenizer.from_pretrained(cfg.fine_tuning.base_model, use_fast=True)
    if tokenizer.pad_token is None:
        tokenizer.pad_token = tokenizer.eos_token or tokenizer.bos_token or tokenizer.cls_token or tokenizer.sep_token

    device_map = 'auto' if torch.cuda.is_available() else None
    torch_dtype = torch.float16 if cfg.fine_tuning.fp16 and torch.cuda.is_available() else torch.float32
    model = AutoModelForCausalLM.from_pretrained(
        cfg.fine_tuning.base_model,
        device_map=device_map,
        torch_dtype=torch_dtype,
        low_cpu_mem_usage=True,
    )

    if use_peft:
        peft_config = LoraConfig(
            r=int(cfg.fine_tuning.peft_r),
            lora_alpha=int(cfg.fine_tuning.peft_alpha),
            target_modules=cfg.fine_tuning.target_modules,
            lora_dropout=float(cfg.fine_tuning.peft_dropout),
            bias='none',
            task_type='CAUSAL_LM',
        )
        model = get_peft_model(model, peft_config)

    tokenized_train = [tokenize_prompt_completion(ex, tokenizer, cfg) for ex in train_examples]
    train_dataset = Dataset.from_dict(tokenized_train)

    eval_dataset = None
    if valid_examples is not None:
        tokenized_valid = [tokenize_prompt_completion(ex, tokenizer, cfg) for ex in valid_examples]
        eval_dataset = Dataset.from_dict(tokenized_valid)

    output_dir = Path(cfg.fine_tuning.output_dir)
    local_model_dir = output_dir / 'local_finetuned_model'
    local_model_dir.mkdir(parents=True, exist_ok=True)

    eval_steps = int(getattr(cfg.fine_tuning, 'eval_steps', cfg.fine_tuning.logging_steps))
    training_args = TrainingArguments(
        output_dir=str(local_model_dir),
        overwrite_output_dir=True,
        per_device_train_batch_size=int(cfg.fine_tuning.per_device_train_batch_size),
        per_device_eval_batch_size=int(cfg.fine_tuning.per_device_eval_batch_size),
        gradient_accumulation_steps=int(cfg.fine_tuning.gradient_accumulation_steps),
        num_train_epochs=float(cfg.fine_tuning.num_train_epochs),
        learning_rate=float(cfg.fine_tuning.learning_rate),
        fp16=bool(cfg.fine_tuning.fp16) and torch.cuda.is_available(),
        evaluation_strategy='steps' if eval_dataset is not None else 'no',
        eval_steps=eval_steps,
        save_steps=int(cfg.fine_tuning.save_steps),
        logging_steps=int(cfg.fine_tuning.logging_steps),
        save_total_limit=int(cfg.fine_tuning.save_total_limit),
        load_best_model_at_end=eval_dataset is not None,
        metric_for_best_model='eval_loss',
        disable_tqdm=not bool(getattr(cfg.fine_tuning, 'show_tqdm', True)),
    )

    trainer = Trainer(
        model=model,
        args=training_args,
        train_dataset=train_dataset,
        eval_dataset=eval_dataset,
        tokenizer=tokenizer,
        data_collator=default_data_collator,
    )

    trainer.train()
    trainer.save_model(local_model_dir)

    metadata_path = output_dir / 'fine_tuning_local_metadata.json'
    metadata = {
        'provider': 'local',
        'base_model': cfg.fine_tuning.base_model,
        'output_dir': str(local_model_dir),
        'num_train_examples': len(train_examples),
        'num_valid_examples': len(valid_examples) if valid_examples is not None else 0,
    }
    with metadata_path.open('w', encoding='utf-8') as handle:
        json.dump(metadata, handle, indent=2)

    log.info(f"Saved local fine-tune model to {local_model_dir}")
    return FineTuneOutputPaths(
        training_file=None,
        validation_file=None,
        job_metadata=metadata_path,
        model_dir=local_model_dir,
    )


def run_fine_tuning(cfg) -> FineTuneOutputPaths:
    annotated_path = get_annotated_csv_path(cfg)
    if not annotated_path.exists():
        raise FileNotFoundError(f"Annotated CSV file not found: {annotated_path}")

    df = pd.read_csv(annotated_path)
    examples = build_examples(cfg, df)
    train_examples, valid_examples = split_examples(cfg, examples)

    output_dir = Path(cfg.fine_tuning.output_dir)
    output_dir.mkdir(parents=True, exist_ok=True)

    if cfg.fine_tuning.provider == 'openai':
        if 'OPENAI_API_KEY' not in os.environ:
            raise EnvironmentError("OPENAI_API_KEY is required for fine-tuning but not set.")

        training_path = output_dir / f"{annotated_path.stem}_train.jsonl"
        write_jsonl(train_examples, training_path)

        validation_path = None
        train_file_id = upload_file_to_openai(training_path)
        validation_file_id = None
        if valid_examples is not None:
            validation_path = output_dir / f"{annotated_path.stem}_valid.jsonl"
            write_jsonl(valid_examples, validation_path)
            validation_file_id = upload_file_to_openai(validation_path)

        job = create_fine_tune_job(training_file_id, cfg, validation_file_id=validation_file_id)
        metadata_path = output_dir / f"fine_tune_job_{job.id}.json"
        with metadata_path.open('w', encoding='utf-8') as handle:
            json.dump(job, handle, indent=2, default=str)

        log.info(f"Fine-tune metadata written to {metadata_path}")
        return FineTuneOutputPaths(
            training_file=training_path,
            validation_file=validation_path,
            job_metadata=metadata_path,
        )
    elif cfg.fine_tuning.provider == 'local':
        return run_local_fine_tuning(cfg, train_examples, valid_examples)
    else:
        raise ValueError(f"Unknown fine_tuning.provider: {cfg.fine_tuning.provider}. Use 'local' or 'openai'.")
